# Set this before building for production so canonical URLs and sitemaps are correct.
SITE_URL=https://your-domain.com
PUBLIC_CONTACT_EMAIL=hello@your-domain.com

# Optional privacy-friendly analytics. Plausible script variant below also tracks file downloads and outbound links.
# PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com
# PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.file-downloads.outbound-links.js

# Gemini / Nano Banana image generation. Keep the real key local only.
# GEMINI_API_KEY=your-local-key
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GENERATED_IMAGE_DIR=incoming/generated
# GENERATED_MANIFEST_PATH=incoming/manifest.generated.json

# AdSense is disabled by default. Only enable after AdSense approval, real slot IDs,
# a final privacy policy, and a Google-certified CMP for EEA/UK/Swiss traffic.
PUBLIC_ADSENSE_ENABLED=false
# PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000
# PUBLIC_ADSENSE_SLOT_LEADERBOARD=0000000000
# PUBLIC_ADSENSE_SLOT_RECTANGLE=0000000000
# PUBLIC_ADSENSE_SLOT_SIDEBAR=0000000000
# PUBLIC_GOOGLE_CERTIFIED_CMP=false

# Optional local notice for non-certified preference UI. This is not a substitute
# for a Google-certified CMP where one is required.
PUBLIC_CONSENT_NOTICE_ENABLED=false
