# Required before production build so canonical URLs and generated site metadata are correct.
SITE_URL=https://your-domain.com
PUBLIC_CONTACT_EMAIL=hello@your-domain.com

# Optional privacy-friendly analytics with file-download and outbound-link tracking.
# PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com
# PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.file-downloads.outbound-links.js
# PUBLIC_PLAUSIBLE_ORIGIN=https://plausible.io

# Keep API keys and generation secrets local/CI-only. Never commit real keys.
# GEMINI_API_KEY=your-local-key
