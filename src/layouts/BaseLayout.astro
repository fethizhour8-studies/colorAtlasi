---
import "../styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Analytics from "@/components/Analytics.astro";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  robots?: "index,follow" | "noindex,follow";
  image?: string;
  jsonLd?: Array<Record<string, unknown>>;
}

const { title, description, canonicalPath, robots = "index,follow", image, jsonLd = [] } = Astro.props;
const siteUrl = (import.meta.env.SITE || "https://example.com").replace(/\/$/, "");
const toAbsoluteUrl = (path?: string) => {
  if (!path) return undefined;
  if (path.startsWith("http://") || path.startsWith("https://")) return path;
  return `${siteUrl}${path.startsWith("/") ? path : `/${path}`}`;
};
const canonicalUrl = toAbsoluteUrl(canonicalPath);
const imageUrl = toAbsoluteUrl(image);
const safeJsonLd = (item: Record<string, unknown>) => JSON.stringify(item).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Nunito+Sans:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
    {jsonLd.map((item) => <script type="application/ld+json" set:html={safeJsonLd(item)} />)}
    <Analytics />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
