---
import Analytics from "@components/Analytics.astro";
import { topNav } from "@lib/catalog";
import { jsonLd, robotsForIndexable } from "@lib/seo";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  image?: string;
  robots?: string;
  jsonLdItems?: unknown[];
}

const { title, description, canonicalPath, image, robots = robotsForIndexable(true), jsonLdItems = [] } = Astro.props;
const site = Astro.site || new URL("https://example.com");
const canonical = new URL(canonicalPath, site).toString();
const absoluteImage = image ? new URL(image, site).toString() : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {absoluteImage && <meta property="og:image" content={absoluteImage} />}
    <meta name="twitter:card" content={absoluteImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {absoluteImage && <meta name="twitter:image" content={absoluteImage} />}
    <meta name="theme-color" content="#FAF7F2" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={jsonLd(item)} />)}
    <Analytics />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/en/" aria-label="Coloring Atlas home">
          <span class="brand-mark" aria-hidden="true">CA</span>
          <span>
            <strong>Coloring Atlas</strong>
            <small>Printable coloring pages and classroom sheets.</small>
          </span>
        </a>
        <nav class="primary-nav" aria-label="Primary navigation">
          {topNav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-grid">
        <section>
          <strong>Coloring Atlas</strong>
          <p>Warm, print-ready PDFs for parents, teachers, kids, and adults.</p>
        </section>
        <section>
          <strong>Browse</strong>
          <p class="footer-links">
            {topNav.map((item) => <a href={item.href}>{item.label}</a>)}
          </p>
        </section>
        <section>
          <strong>Trust</strong>
          <p class="footer-links">
            <a href="/en/about/">About</a>
            <a href="/en/contact/">Contact</a>
            <a href="/en/privacy-policy/">Privacy Policy</a>
            <a href="/en/licensing/">Licensing</a>
          </p>
        </section>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --paper: #faf7f2;
    --surface: #ffffff;
    --ink: #1a1a2e;
    --muted: #626274;
    --border: #e8e2d9;
    --teal: #2d9f93;
    --teal-dark: #167d78;
    --coral: #f06b52;
    --sunshine: #f4c95d;
    --green: #4caf7d;
    --teacher-blue: #5b7fd6;
    --adult-lavender: #8b7fc7;
    --kids-peach: #ffb38a;
    --sky: #bfe7f5;
    --mint: #ddf5e7;
    --pink: #ffe1e8;
    --yellow-soft: #fff2b8;
    --shadow: 0 14px 34px rgba(26, 26, 46, 0.08);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background: var(--paper);
    color: var(--ink);
  }

  body {
    line-height: 1.55;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--teal-dark);
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3 {
    line-height: 1.12;
    letter-spacing: 0;
  }

  h1 {
    max-width: 880px;
    font-size: clamp(2.15rem, 5vw, 4.15rem);
  }

  h2 {
    font-size: clamp(1.55rem, 3vw, 2.45rem);
  }

  h3 {
    font-size: 1.08rem;
  }

  p {
    color: var(--muted);
  }

  .skip-link {
    position: absolute;
    left: 1rem;
    top: -3rem;
    z-index: 20;
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    background: var(--ink);
    color: white;
  }

  .skip-link:focus {
    top: 1rem;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--border);
    background: rgba(250, 247, 242, 0.94);
    backdrop-filter: blur(12px);
  }

  .header-inner,
  .section,
  .footer-grid {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  .header-inner {
    display: grid;
    grid-template-columns: minmax(220px, auto) minmax(0, 1fr);
    align-items: center;
    gap: 1.2rem;
    min-height: 76px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .brand-mark {
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 2px solid var(--ink);
    border-radius: 10px;
    background: var(--sunshine);
    font-weight: 850;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand small {
    max-width: 280px;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .primary-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem;
  }

  .primary-nav a {
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.48rem 0.72rem;
    color: var(--muted);
    font-size: 0.92rem;
    white-space: nowrap;
  }

  .primary-nav a:hover {
    border-color: var(--border);
    background: var(--surface);
    color: var(--ink);
    box-shadow: 0 7px 18px rgba(26, 26, 46, 0.06);
  }

  .section {
    padding: 46px 0;
  }

  .section-tight {
    padding: 28px 0;
  }

  .eyebrow {
    margin-bottom: 0.5rem;
    color: var(--coral);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .lead {
    max-width: 760px;
    margin-top: 1rem;
    font-size: 1.08rem;
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .grid-4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .panel,
  .card,
  .printable-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .button,
  .ghost-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border-radius: 8px;
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--ink);
    font-weight: 800;
  }

  .button {
    background: var(--ink);
    color: white;
  }

  .button:hover {
    background: var(--teal-dark);
    color: white;
  }

  .ghost-button {
    background: var(--surface);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #f7fbf4;
    padding: 0.3rem 0.55rem;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 650;
  }

  .breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .breadcrumbs a {
    text-decoration: underline;
    text-underline-offset: 0.18rem;
  }

  .site-footer {
    margin-top: 2rem;
    border-top: 1px solid var(--border);
    background: #eef4f2;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 0.8fr;
    gap: 1rem;
    padding: 30px 0;
  }

  .footer-links {
    display: grid;
    gap: 0.24rem;
    margin-top: 0.45rem;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 0.16rem;
  }

  @media (max-width: 900px) {
    .header-inner {
      grid-template-columns: 1fr;
      gap: 0.6rem;
      padding: 0.8rem 0;
    }

    .primary-nav {
      justify-content: flex-start;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 0.25rem;
    }

    .grid-4,
    .grid-3 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .header-inner,
    .section,
    .footer-grid {
      width: min(100% - 22px, 1180px);
    }

    .section {
      padding: 34px 0;
    }

    .grid-4,
    .grid-3,
    .grid-2 {
      grid-template-columns: 1fr;
    }

    .button,
    .ghost-button {
      width: 100%;
    }
  }
</style>
