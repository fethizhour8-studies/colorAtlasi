---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CollectionCard from "@components/CollectionCard.astro";
import HelpfulGuide from "@components/HelpfulGuide.astro";
import PrintableGrid from "@components/PrintableGrid.astro";
import QuickFacts from "@components/QuickFacts.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  getBreadcrumbsForTopic,
  getPagesForTopic,
  getRelatedTopics,
  getTopicPath,
  type Topic,
} from "@lib/catalog";
import { breadcrumbJsonLd, collectionJsonLd, faqJsonLd } from "@lib/seo";

interface Props {
  topic: Topic;
}

const { topic } = Astro.props;
const site = Astro.site || new URL("https://example.com");
const printables = getPagesForTopic(topic.id);
const crumbs = getBreadcrumbsForTopic(topic);
const relatedTopics = getRelatedTopics(topic);
const facts = [
  { label: "Pages", value: printables.length },
  { label: "Format", value: topic.quickFacts.format },
  { label: "Paper", value: topic.quickFacts.paperSize },
  { label: "Difficulty", value: topic.difficulty },
];
const faqItems = [
  {
    question: `Are these ${topic.title.toLowerCase()} free to print?`,
    answer: `${topic.quickFacts.license}. Open a PDF, download it, and print it for simple home or classroom use.`,
  },
  {
    question: `What paper size should I use for ${topic.title.toLowerCase()}?`,
    answer: `The PDFs are prepared for ${topic.quickFacts.paperSize}. If you print on A4, choose fit to page in your printer settings.`,
  },
  {
    question: `Can teachers use these ${topic.title.toLowerCase()} in class?`,
    answer: "Yes. Collections marked for classroom use are designed for packets, early finishers, quiet activities, and simple lesson add-ons.",
  },
];
---

<BaseLayout
  title={topic.seo.title}
  description={topic.seo.metaDescription}
  canonicalPath={getTopicPath(topic)}
  image={printables[0]?.files.preview}
  jsonLdItems={[collectionJsonLd(topic, getTopicPath(topic), site), breadcrumbJsonLd(crumbs, site), faqJsonLd(faqItems)]}
>
  <section class="section">
    <Breadcrumbs crumbs={crumbs} />
    <p class="eyebrow">Printable collection</p>
    <h1>{topic.title}</h1>
    <p class="lead">{topic.intro}</p>
    <QuickFacts facts={facts} />
  </section>

  <section class="section section-tight">
    <div class="topic-layout">
      <div>
        <p class="eyebrow">Free PDF downloads</p>
        <h2>Choose a printable</h2>
        <PrintableGrid pages={printables} />
      </div>
      <aside class="panel side-panel">
        <h2>Helpful notes</h2>
        <p>Download the PDF below the printable you like. Print at actual size for US Letter, or choose fit to page for A4.</p>
        <p>{topic.quickFacts.license}.</p>
        <div class="chip-list">
          {topic.audiences.map((audience) => <span class="pill">{audience}</span>)}
          {topic.tags.map((tag) => <span class="pill">{tag}</span>)}
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <HelpfulGuide title={topic.title} audience={topic.audiences} license={topic.quickFacts.license} />
  </section>

  <section class="section section-tight">
    <div class="panel faq-panel">
      <p class="eyebrow">FAQ</p>
      <h2>Questions about {topic.title.toLowerCase()}</h2>
      <div class="faq-list">
        {faqItems.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {relatedTopics.length > 0 && (
    <section class="section">
      <p class="eyebrow">Related</p>
      <h2>Browse related collections</h2>
      <div class="grid grid-4 card-grid">
        {relatedTopics.map((item) => (
          <CollectionCard title={item.title} description={item.description} href={getTopicPath(item)} count={getPagesForTopic(item.id).length} cta="Open collection" />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .topic-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 1.2rem;
    align-items: start;
  }

  .side-panel,
  .faq-panel {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
  }

  .side-panel {
    position: sticky;
    top: 98px;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .faq-list {
    display: grid;
    gap: 0.65rem;
  }

  details {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #fff;
    padding: 0.8rem;
  }

  summary {
    cursor: pointer;
    font-weight: 800;
  }

  details p {
    margin-top: 0.55rem;
  }

  .card-grid,
  :global(.printable-grid) {
    margin-top: 1rem;
  }

  @media (max-width: 980px) {
    .topic-layout {
      grid-template-columns: 1fr;
    }

    .side-panel {
      position: static;
    }
  }
</style>
