---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CollectionCard from "@components/CollectionCard.astro";
import PrintableGrid from "@components/PrintableGrid.astro";
import QuickFacts from "@components/QuickFacts.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  getBreadcrumbsForTopic,
  getPagesForTopic,
  getRelatedTopics,
  getTopicPath,
  type Topic,
} from "@lib/catalog";
import { breadcrumbJsonLd, collectionJsonLd } from "@lib/seo";

interface Props {
  topic: Topic;
}

const { topic } = Astro.props;
const site = Astro.site || new URL("https://example.com");
const printables = getPagesForTopic(topic.id);
const crumbs = getBreadcrumbsForTopic(topic);
const relatedTopics = getRelatedTopics(topic);
const facts = [
  { label: "Pages", value: printables.length },
  { label: "Format", value: topic.quickFacts.format },
  { label: "Paper", value: topic.quickFacts.paperSize },
  { label: "Difficulty", value: topic.difficulty },
];
---

<BaseLayout
  title={topic.seo.title}
  description={topic.seo.metaDescription}
  canonicalPath={getTopicPath(topic)}
  image={printables[0]?.files.preview}
  jsonLdItems={[collectionJsonLd(topic, getTopicPath(topic), site), breadcrumbJsonLd(crumbs, site)]}
>
  <section class="section">
    <Breadcrumbs crumbs={crumbs} />
    <p class="eyebrow">Printable collection</p>
    <h1>{topic.title}</h1>
    <p class="lead">{topic.intro}</p>
    <QuickFacts facts={facts} />
  </section>

  <section class="section section-tight">
    <div class="topic-layout">
      <div>
        <p class="eyebrow">Free PDF downloads</p>
        <h2>Choose a printable</h2>
        <PrintableGrid pages={printables} />
      </div>
      <aside class="panel side-panel">
        <h2>Helpful notes</h2>
        <p>Download the PDF below the printable you like. Print at actual size for US Letter, or choose fit to page for A4.</p>
        <p>{topic.quickFacts.license}.</p>
        <div class="chip-list">
          {topic.tags.map((tag) => <span class="pill">{tag}</span>)}
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="panel guide-panel">
      <h2>Printing tips for {topic.title.toLowerCase()}</h2>
      <p>For younger kids, plain copy paper works well with crayons and colored pencils. For detailed adult pages, heavier paper can make markers and fine pens feel cleaner.</p>
      <p>Teachers can print a few choices for quiet time, early finishers, centers, or seasonal packets without needing extra editing software.</p>
    </div>
  </section>

  {relatedTopics.length > 0 && (
    <section class="section">
      <p class="eyebrow">Related</p>
      <h2>Browse related collections</h2>
      <div class="grid grid-4 card-grid">
        {relatedTopics.map((item) => (
          <CollectionCard title={item.title} description={item.description} href={getTopicPath(item)} count={getPagesForTopic(item.id).length} cta="Open collection" />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .topic-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 1.2rem;
    align-items: start;
  }

  .side-panel,
  .guide-panel {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
  }

  .side-panel {
    position: sticky;
    top: 98px;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .card-grid,
  :global(.printable-grid) {
    margin-top: 1rem;
  }

  @media (max-width: 980px) {
    .topic-layout {
      grid-template-columns: 1fr;
    }

    .side-panel {
      position: static;
    }
  }
</style>
