---
import CollectionCard from "@components/CollectionCard.astro";
import PrintableGrid from "@components/PrintableGrid.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  contentTypes,
  getContentTypePath,
  getHubPath,
  getPagesForHub,
  getPagesForTopic,
  getTopicPath,
  hubs,
  pages,
  topics,
  type Topic,
} from "@lib/catalog";
import { websiteJsonLd } from "@lib/seo";

const site = Astro.site || new URL("https://example.com");
const safeLaunchTopicIds = [
  "dinosaur-coloring-pages",
  "cute-coloring-pages",
  "rainforest-animals-coloring-pages",
  "mandala-coloring-pages",
  "relaxing-coloring-pages",
  "christmas-coloring-pages",
  "2026-printable-calendars",
];
const isTopic = (topic: Topic | undefined): topic is Topic => Boolean(topic);
const featuredTopics = safeLaunchTopicIds.map((id) => topics.find((topic) => topic.id === id)).filter(isTopic).slice(0, 6);
const newPrintables = pages.slice(0, 6);
const seasonalTopics = topics.filter((topic) => topic.hubId === "seasonal" || topic.tags.some((tag) => ["seasonal", "holiday", "christmas"].includes(tag))).slice(0, 4);
const calendarTopics = topics.filter((topic) => topic.contentTypeId === "calendars").slice(0, 4);
---

<BaseLayout
  title="Free Printable Coloring Pages, Sheets, Calendars and PDFs | Coloring Atlas"
  description="Browse organized, print-ready PDF coloring pages, coloring sheets, calendars, worksheets, mandalas, and safe classroom printables."
  canonicalPath="/en/"
  image={newPrintables[0]?.files.preview}
  jsonLdItems={[websiteJsonLd(site)]}
>
  <section class="hero">
    <div class="section hero-grid">
      <div>
        <p class="eyebrow">Free PDF printables</p>
        <h1>Printable coloring pages and simple sheets for real life</h1>
        <p class="lead">Browse clean PDF coloring pages, calendars, worksheets, mandalas, and classroom-friendly printables that are easy to download and print.</p>
        <form class="search-box" action="/en/coloring-pages/" method="get" role="search">
          <label for="home-search">Find printable collections</label>
          <div>
            <input id="home-search" name="q" type="search" placeholder="Try dinosaurs, mandalas, animals, calendars..." />
            <button type="submit">Search</button>
          </div>
        </form>
        <div class="button-row hero-actions">
          <a class="button" href="/en/coloring-pages/">Browse coloring pages</a>
          <a class="ghost-button" href="#collections">Explore collections</a>
        </div>
      </div>
      <div class="hero-preview" aria-label="Printable previews">
        {newPrintables.slice(0, 4).map((page) => (
          <span>
            <img src={page.files.thumbnail} alt="" />
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tight trust-strip">
    <div class="trust-panel">
      <div>
        <strong>Free PDF downloads</strong>
        <p>No sign-up required for standard printable pages.</p>
      </div>
      <div>
        <strong>Rights-safe topics</strong>
        <p>Built around original, generic, classroom-safe themes.</p>
      </div>
      <div>
        <strong>Print-first layout</strong>
        <p>US Letter PDFs with clean previews and simple instructions.</p>
      </div>
      <div>
        <strong>Made for real use</strong>
        <p>Parents, teachers, kids, adults, quiet time, and class packets.</p>
      </div>
    </div>
  </section>

  <section class="section section-tight" id="collections">
    <p class="eyebrow">Start browsing</p>
    <h2>Popular printable areas</h2>
    <div class="grid grid-3 card-grid">
      {contentTypes.map((contentType) => (
        <CollectionCard
          title={contentType.title}
          description={contentType.description}
          href={getContentTypePath(contentType)}
          count={contentType.id === "coloring-pages" ? pages.length : undefined}
          accent={contentType.accent}
          cta="Browse"
        />
      ))}
    </div>
  </section>

  <section class="section">
    <p class="eyebrow">Safe launch picks</p>
    <h2>Popular collections without character or brand risk</h2>
    <div class="grid grid-3 card-grid">
      {featuredTopics.map((topic) => (
        <CollectionCard
          title={topic.title}
          description={topic.description}
          href={getTopicPath(topic)}
          count={getPagesForTopic(topic.id).length}
          accent={topic.hubId === "mandalas" || topic.hubId === "adults" ? "adult-lavender" : "kids-peach"}
          cta="Open collection"
        />
      ))}
    </div>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">Featured hubs</p>
      <h2>Simple paths for parents and teachers</h2>
      <div class="grid grid-2 card-grid">
        {hubs.slice(0, 4).map((hub) => (
          <CollectionCard
            title={hub.title}
            description={hub.description}
            href={getHubPath(hub)}
            count={getPagesForHub(hub.id).length}
            accent={hub.accent}
            cta="Browse hub"
          />
        ))}
      </div>
    </div>
    <aside class="panel idea-panel">
      <p class="eyebrow">Quick activity ideas</p>
      <h2>Use printables fast</h2>
      <ul>
        <li>Print a mini packet for early finishers.</li>
        <li>Pair animal pages with nature lessons.</li>
        <li>Use mandalas for calm creative breaks.</li>
        <li>Keep calendars for home and classroom planning.</li>
      </ul>
    </aside>
  </section>

  {(seasonalTopics.length > 0 || calendarTopics.length > 0) && (
    <section class="section section-tight">
      <p class="eyebrow">Timely printables</p>
      <h2>Seasonal and calendar pages</h2>
      <div class="grid grid-4 card-grid">
        {[...seasonalTopics, ...calendarTopics].slice(0, 8).map((topic) => (
          <CollectionCard
            title={topic.title}
            description={topic.description}
            href={getTopicPath(topic)}
            count={getPagesForTopic(topic.id).length}
            accent={topic.contentTypeId === "calendars" ? "mint" : "coral"}
            cta="View PDFs"
          />
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <p class="eyebrow">New PDFs</p>
    <h2>Latest printable pages</h2>
    <PrintableGrid pages={newPrintables} />
  </section>
</BaseLayout>

<style>
  .hero {
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(circle at 84% 22%, rgba(244, 201, 93, 0.3), transparent 28%),
      linear-gradient(180deg, #fff, var(--paper));
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.75fr);
    gap: 2rem;
    align-items: center;
  }

  .hero-actions,
  .card-grid {
    margin-top: 1rem;
  }

  .search-box {
    display: grid;
    gap: 0.45rem;
    max-width: 680px;
    margin-top: 1.25rem;
  }

  .search-box label {
    font-weight: 800;
  }

  .search-box div {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.55rem;
  }

  .search-box input,
  .search-box button {
    min-height: 48px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font: inherit;
  }

  .search-box input {
    padding: 0 0.9rem;
    background: #fff;
  }

  .search-box button {
    border-color: var(--ink);
    background: var(--ink);
    color: #fff;
    padding: 0 1rem;
    font-weight: 850;
  }

  .hero-preview {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .hero-preview span {
    display: grid;
    aspect-ratio: 4 / 3;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: linear-gradient(135deg, var(--yellow-soft), var(--mint));
    box-shadow: var(--shadow);
  }

  .hero-preview img {
    width: 86%;
    height: 86%;
    object-fit: contain;
    border-radius: 6px;
    background: #fff;
    box-shadow: 0 10px 20px rgba(26, 26, 46, 0.12);
  }

  .trust-panel {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #fff;
    padding: 1rem;
    box-shadow: var(--shadow);
  }

  .split-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 330px;
    gap: 1.2rem;
    align-items: start;
  }

  .idea-panel {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
    background: linear-gradient(135deg, #fff, var(--mint));
  }

  .idea-panel ul {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .hero-grid,
    .trust-panel,
    .split-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .search-box div {
      grid-template-columns: 1fr;
    }
  }
</style>
