---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CollectionCard from "@components/CollectionCard.astro";
import HelpfulGuide from "@components/HelpfulGuide.astro";
import PrintableGrid from "@components/PrintableGrid.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  getBreadcrumbsForHub,
  getHubPath,
  getPagesForHub,
  getPagesForTopic,
  getTopicPath,
  getTopicsForHub,
  type Hub,
} from "@lib/catalog";
import { breadcrumbJsonLd, collectionJsonLd } from "@lib/seo";

interface Props {
  hub: Hub;
}

const { hub } = Astro.props;
const site = Astro.site || new URL("https://example.com");
const topics = getTopicsForHub(hub.id);
const printables = getPagesForHub(hub.id);
const crumbs = getBreadcrumbsForHub(hub);
const featuredTopics = topics.slice(0, 6);
---

<BaseLayout
  title={hub.seo.title}
  description={hub.seo.metaDescription}
  canonicalPath={getHubPath(hub)}
  image={printables[0]?.files.preview}
  jsonLdItems={[collectionJsonLd(hub, getHubPath(hub), site), breadcrumbJsonLd(crumbs, site)]}
>
  <section class="section hub-hero">
    <Breadcrumbs crumbs={crumbs} />
    <p class="eyebrow">Printable hub</p>
    <h1>{hub.title}</h1>
    <p class="lead">{hub.description}</p>
    <div class="hub-stats">
      <span><strong>{topics.length}</strong> collections</span>
      <span><strong>{printables.length}</strong> printables</span>
      <span><strong>{hub.audiences.join(" / ")}</strong></span>
    </div>
  </section>

  <section class="section section-tight">
    <p class="eyebrow">Collections</p>
    <h2>Browse {hub.navTitle.toLowerCase()} topics</h2>
    <div class="grid grid-3 card-grid">
      {topics.map((topic) => (
        <CollectionCard
          title={topic.title}
          description={topic.description}
          href={getTopicPath(topic)}
          count={getPagesForTopic(topic.id).length}
          accent={hub.accent}
          cta="Open collection"
        />
      ))}
    </div>
  </section>

  {featuredTopics.length > 0 && (
    <section class="section section-tight">
      <p class="eyebrow">Featured paths</p>
      <h2>Start with these popular collections</h2>
      <div class="feature-row">
        {featuredTopics.map((topic) => (
          <a class="feature-pill" href={getTopicPath(topic)}>{topic.title}</a>
        ))}
      </div>
    </section>
  )}

  {printables.length > 0 && (
    <section class="section">
      <p class="eyebrow">New PDFs</p>
      <h2>Latest in {hub.navTitle}</h2>
      <PrintableGrid pages={printables.slice(0, 9)} />
    </section>
  )}

  <section class="section">
    <HelpfulGuide title={hub.title} audience={hub.audiences} variant="hub" />
  </section>
</BaseLayout>

<style>
  .hub-hero {
    background:
      radial-gradient(circle at 82% 18%, rgba(244, 201, 93, 0.22), transparent 28%),
      linear-gradient(180deg, #fff, transparent);
  }

  .card-grid,
  :global(.printable-grid) {
    margin-top: 1rem;
  }

  .hub-stats,
  .feature-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.1rem;
  }

  .hub-stats span,
  .feature-pill {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    padding: 0.45rem 0.7rem;
    color: var(--muted);
    box-shadow: 0 8px 20px rgba(26, 26, 46, 0.05);
  }

  .hub-stats strong {
    color: var(--ink);
  }

  .feature-pill {
    color: var(--teal-dark);
    font-weight: 800;
  }
</style>
