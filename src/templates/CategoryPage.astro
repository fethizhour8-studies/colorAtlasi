---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CollectionCard from "@components/CollectionCard.astro";
import PrintableGrid from "@components/PrintableGrid.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  getBreadcrumbsForHub,
  getHubPath,
  getPagesForHub,
  getPagesForTopic,
  getTopicPath,
  getTopicsForHub,
  type Hub,
} from "@lib/catalog";
import { breadcrumbJsonLd, collectionJsonLd } from "@lib/seo";

interface Props {
  hub: Hub;
}

const { hub } = Astro.props;
const site = Astro.site || new URL("https://example.com");
const topics = getTopicsForHub(hub.id);
const printables = getPagesForHub(hub.id);
const crumbs = getBreadcrumbsForHub(hub);
---

<BaseLayout
  title={hub.seo.title}
  description={hub.seo.metaDescription}
  canonicalPath={getHubPath(hub)}
  image={printables[0]?.files.preview}
  jsonLdItems={[collectionJsonLd(hub, getHubPath(hub), site), breadcrumbJsonLd(crumbs, site)]}
>
  <section class="section">
    <Breadcrumbs crumbs={crumbs} />
    <p class="eyebrow">Printable hub</p>
    <h1>{hub.title}</h1>
    <p class="lead">{hub.description}</p>
  </section>

  <section class="section section-tight">
    <p class="eyebrow">Collections</p>
    <h2>Browse {hub.navTitle.toLowerCase()} topics</h2>
    <div class="grid grid-3 card-grid">
      {topics.map((topic) => (
        <CollectionCard
          title={topic.title}
          description={topic.description}
          href={getTopicPath(topic)}
          count={getPagesForTopic(topic.id).length}
          accent={hub.accent}
          cta="Open collection"
        />
      ))}
    </div>
  </section>

  {printables.length > 0 && (
    <section class="section">
      <p class="eyebrow">New PDFs</p>
      <h2>Latest in {hub.navTitle}</h2>
      <PrintableGrid pages={printables.slice(0, 9)} />
    </section>
  )}
</BaseLayout>

<style>
  .card-grid {
    margin-top: 1rem;
  }
</style>
