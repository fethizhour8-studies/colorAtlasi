---
import PrintableCard from "@/components/PrintableCard.astro";
import CollectionCard from "@/components/CollectionCard.astro";
import type { Topic } from "@/lib/catalog";
import { getPrintablesForTopic, getPublicRelatedTopics, getTopicPath } from "@/lib/catalog";

interface Props {
  topic: Topic;
}

const { topic } = Astro.props;
const printables = getPrintablesForTopic(topic.id);
const relatedTopics = getPublicRelatedTopics(topic);
const topicLower = topic.title.toLowerCase();
const isCalendar = topic.tags.includes("calendar") || topicLower.includes("calendar");
const isAdult = topic.tags.includes("adult coloring") || topic.tags.includes("relaxing") || topicLower.includes("mandala") || topicLower.includes("adult");
const useCase = isCalendar
  ? "family schedules, classroom planning, desk organization, and quick monthly notes"
  : isAdult
    ? "quiet creative breaks, mindful coloring, evening relaxation, and screen-free downtime"
    : "early finishers, rainy days, classroom packets, weekend crafts, and screen-free creative time";
const contentSections = topic.sections || [];
---

<section class="container-page py-8">
  <div class="grid gap-8 lg:grid-cols-[1fr_280px] lg:items-start">
    <div>
      <div class="mb-4 rounded-2xl border-2 border-coral/35 bg-ivory p-4 text-center shadow-soft">
        <p class="text-sm font-black text-ink">
          {printables.length > 0 ? "Choose a printable, preview it, then download the PDF." : "This collection is ready for printables from the asset pipeline."}
        </p>
        <div class="mt-3 flex flex-wrap justify-center gap-3 text-xs font-black">
          <a href="#printable-grid" class="rounded-full border border-sky bg-white px-4 py-2 text-sky-dark">View pages</a>
          <a href="#how-to-use" class="rounded-full border border-line bg-white px-4 py-2 text-muted">Printing tips</a>
          {contentSections.length > 0 && <a href="#collection-guide" class="rounded-full border border-line bg-white px-4 py-2 text-muted">Ideas</a>}
          <a href="#faq" class="rounded-full border border-line bg-white px-4 py-2 text-muted">FAQ</a>
        </div>
      </div>

      <div id="printable-grid" class={printables.length > 0 ? "grid grid-cols-2 gap-4 sm:grid-cols-3" : ""}>
        {printables.length > 0 ? (
          printables.map((printable) => <PrintableCard printable={printable} />)
        ) : (
          <div class="rounded-3xl border-2 border-dashed border-line bg-paper p-8 text-center">
            <p class="eyebrow">Coming soon</p>
            <h2 class="mt-3 font-serif text-3xl font-black text-ink">Printable pages are being prepared</h2>
            <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-muted">
              This safe collection page is already part of the catalogue so internal links, SEO planning,
              and future PDF uploads have a clear home. Add approved assets through the pipeline when
              the printables are ready.
            </p>
          </div>
        )}
      </div>
    </div>

    <aside class="grid gap-4 lg:sticky lg:top-24">
      <div class="sidebar-box p-4">
        <h2 class="font-serif text-xl font-black text-ink">Quick facts</h2>
        <dl class="mt-4 grid gap-3">
          {
            topic.quickFacts.map((fact) => (
              <div>
                <dt class="text-[0.68rem] font-black uppercase text-muted">{fact.label}</dt>
                <dd class="mt-1 text-sm font-bold leading-5 text-ink">{fact.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
      <div class="sidebar-box p-4">
        <h2 class="font-serif text-xl font-black text-ink">Browse tags</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {
            topic.tags.map((tag) => (
              <span class="rounded-full border border-line bg-paper px-2 py-1 text-xs font-bold text-muted">
                {tag}
              </span>
            ))
          }
        </div>
      </div>
      <div class="sidebar-box bg-mint/50 p-4">
        <h2 class="font-serif text-xl font-black text-ink">Safe topic note</h2>
        <p class="mt-3 text-sm leading-6 text-muted">
          This collection is built around original printable ideas rather than protected characters,
          brand mascots, logos, or franchise designs.
        </p>
      </div>
    </aside>
  </div>
</section>

<section id="how-to-use" class="section-rule content-page py-10">
  <div class="grid gap-6 md:grid-cols-3">
    <div>
      <p class="eyebrow">What is included</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-ink">Printable PDFs for {topicLower}</h2>
      <p class="mt-4 text-sm leading-7 text-muted">
        This collection includes individual PDF printables with large previews, clear titles, and
        direct download buttons. The printable grid appears near the top so you can choose a page
        quickly before reading extra tips.
      </p>
    </div>
    <div>
      <p class="eyebrow">Best for</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-ink">Simple real-life uses</h2>
      <p class="mt-4 text-sm leading-7 text-muted">
        Use these pages for {useCase}. Print one page for a quick activity or save a few favorites
        for repeat use.
      </p>
    </div>
    <div>
      <p class="eyebrow">How to print</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-ink">Clean print settings</h2>
      <p class="mt-4 text-sm leading-7 text-muted">
        Open the PDF, print at actual size on US Letter paper, or choose fit to page for A4. Plain
        copy paper works for crayons and pencils; heavier paper is better for markers.
      </p>
    </div>
  </div>
</section>

{
  contentSections.length > 0 && (
    <section id="collection-guide" class="content-page py-10">
      <div class="grid gap-5">
        <p class="eyebrow">Collection guide</p>
        <h2 class="font-serif text-3xl font-black text-ink">Ideas for using {topicLower}</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {contentSections.map((section) => (
            <article class="sidebar-box p-5">
              {section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
              <h3 class="mt-2 font-serif text-2xl font-black text-ink">{section.title}</h3>
              <p class="mt-3 text-sm leading-7 text-muted">{section.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<section id="faq" class="content-page py-10">
  <div class="grid gap-5">
    <p class="eyebrow">FAQ</p>
    <h2 class="font-serif text-3xl font-black text-ink">Common questions</h2>
    <div class="grid gap-4 md:grid-cols-2">
      <div class="sidebar-box p-4">
        <h3 class="font-serif text-xl font-black text-ink">Can I use these in a classroom?</h3>
        <p class="mt-3 text-sm leading-6 text-muted">
          Yes, these printables are intended for personal, home, and classroom use unless a page
          says otherwise.
        </p>
      </div>
      <div class="sidebar-box p-4">
        <h3 class="font-serif text-xl font-black text-ink">Do I need special software?</h3>
        <p class="mt-3 text-sm leading-6 text-muted">
          No. Open the PDF in your browser or PDF viewer, then print it with your normal printer
          settings.
        </p>
      </div>
      <div class="sidebar-box p-4">
        <h3 class="font-serif text-xl font-black text-ink">Why are individual pages noindex?</h3>
        <p class="mt-3 text-sm leading-6 text-muted">
          Thin printable pages point search engines back to the stronger collection page, where
          visitors can compare previews and find related PDFs.
        </p>
      </div>
      <div class="sidebar-box p-4">
        <h3 class="font-serif text-xl font-black text-ink">Can I share a download link?</h3>
        <p class="mt-3 text-sm leading-6 text-muted">
          Share the collection page whenever possible so people can see the preview, license notes,
          related pages, and printing tips.
        </p>
      </div>
    </div>
  </div>
</section>

{
  relatedTopics.length > 0 && (
    <section class="container-page section-rule py-10">
      <h2 class="mb-5 text-center font-serif text-3xl font-black text-coral-dark">More printable collections</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          relatedTopics.map((relatedTopic) => (
            <CollectionCard
              title={relatedTopic.title}
              description={relatedTopic.description}
              href={getTopicPath(relatedTopic)}
              eyebrow="Related"
            />
          ))
        }
      </div>
    </section>
  )
}
