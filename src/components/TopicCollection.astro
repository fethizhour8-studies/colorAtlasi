---
import PrintableCard from "@/components/PrintableCard.astro";
import CollectionCard from "@/components/CollectionCard.astro";
import type { Topic } from "@/lib/catalog";
import { getPrintablesForTopic, getPublicRelatedTopics, getTopicPath } from "@/lib/catalog";

interface Props {
  topic: Topic;
}

const { topic } = Astro.props;
const printables = getPrintablesForTopic(topic.id);
const relatedTopics = getPublicRelatedTopics(topic);
const topicLower = topic.title.toLowerCase();
const isCalendar = topic.tags.includes("calendar") || topicLower.includes("calendar");
const isAdult = topic.tags.includes("adult coloring") || topic.tags.includes("relaxing") || topicLower.includes("mandala") || topicLower.includes("adult");
const useCase = isCalendar
  ? "family schedules, classroom planning, desk organization, and quick monthly notes"
  : isAdult
    ? "quiet creative breaks, mindful coloring, evening relaxation, and screen-free downtime"
    : "early finishers, rainy days, classroom packets, weekend crafts, and screen-free creative time";
const contentSections = topic.sections || [];
const featuredPrintable = printables[0];
---

<article class="content-page py-8">
  <div class="rounded-[2rem] border border-line bg-paper p-5 shadow-soft md:p-8">
    <section class="prose-block">
      <p class="eyebrow">Printable collection</p>
      <h2 class="mt-3 font-serif text-3xl font-black leading-tight text-ink">About these {topicLower}</h2>
      <p class="mt-4 text-base leading-8 text-muted">
        {topic.intro} This collection works like a printable pack: start with the overview, browse
        the preview grid, download a page directly, or open an individual printable page when you
        want to share one file.
      </p>
    </section>

    {featuredPrintable && (
      <figure class="mx-auto mt-6 max-w-3xl rounded-2xl border border-line bg-white p-4 shadow-soft">
        <div class="aspect-[16/9] rounded-xl bg-ivory p-4">
          <div class="relative h-full overflow-hidden rounded border border-ink/20 bg-white">
            <span class="absolute left-[16%] top-[16%] size-20 rounded-full border-2 border-ink/38"></span>
            <span class="absolute right-[18%] top-[24%] size-14 rounded-full border-2 border-ink/28"></span>
            <span class="absolute bottom-[21%] left-[14%] h-28 w-[72%] rounded-t-full border-2 border-b-0 border-ink/34"></span>
            <span class="absolute bottom-[12%] left-[11%] h-14 w-[78%] rounded-b-2xl border-2 border-ink/34"></span>
            <span class="absolute left-[22%] top-[50%] h-2 w-[56%] rounded-full bg-pencil/55"></span>
            <span class="absolute left-[30%] top-[59%] h-2 w-[40%] rounded-full bg-sage/22"></span>
          </div>
        </div>
      </figure>
    )}

    <nav class="my-8 rounded-2xl border border-coral/35 bg-ivory p-5 shadow-soft" aria-label="Collection page sections">
      <p class="text-sm font-black text-ink">Jump to the printables, search the site, or keep reading for ideas and printing tips.</p>
      <div class="mt-3 flex flex-wrap gap-3 text-xs font-black">
        <a href="#printable-grid" class="rounded-full border border-sky bg-white px-4 py-2 text-sky-dark">Printable pages</a>
        <a href="#site-search" class="rounded-full border border-line bg-white px-4 py-2 text-muted">Search site</a>
        <a href="#craft-ideas" class="rounded-full border border-line bg-white px-4 py-2 text-muted">Craft ideas</a>
        <a href="#printing-tips" class="rounded-full border border-line bg-white px-4 py-2 text-muted">Printing tips</a>
        {relatedTopics.length > 0 && <a href="#related" class="rounded-full border border-line bg-white px-4 py-2 text-muted">Related</a>}
        <a href="#faq" class="rounded-full border border-line bg-white px-4 py-2 text-muted">FAQ</a>
      </div>
    </nav>

    <section id="printable-grid" class="py-3">
      <div class="mb-5">
        <p class="eyebrow">Free PDF downloads</p>
        <h2 class="mt-3 font-serif text-3xl font-black text-ink">Printable pages in this pack</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Click a preview or title to download the PDF directly. Use the View page link when you want
          the individual noindex page for one printable.
        </p>
      </div>

      {printables.length > 0 ? (
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-3">
          {printables.map((printable) => <PrintableCard printable={printable} />)}
        </div>
      ) : (
        <div class="rounded-3xl border-2 border-dashed border-line bg-white p-8 text-center">
          <p class="eyebrow">Coming soon</p>
          <h2 class="mt-3 font-serif text-3xl font-black text-ink">Printable pages are being prepared</h2>
          <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-muted">
            This safe collection page is already part of the catalogue so internal links, SEO planning,
            and future PDF uploads have a clear home. Add approved assets through the pipeline when
            the printables are ready.
          </p>
        </div>
      )}
    </section>

    <section id="site-search" class="section-rule py-8">
      <p class="eyebrow">Search the catalogue</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-ink">Find more printable pages</h2>
      <form class="mt-5 grid gap-3 md:grid-cols-[minmax(0,1fr)_auto]" role="search" action="/en/search/">
        <label class="sr-only" for={`site-search-${topic.id}`}>Search Color Atlas</label>
        <input
          id={`site-search-${topic.id}`}
          name="q"
          type="search"
          placeholder="Search animals, mandalas, calendars, worksheets..."
          class="min-h-12 rounded-full border border-line bg-white px-4 text-sm font-bold text-ink outline-none focus:border-sky"
        />
        <button type="submit" class="button-secondary min-h-12 px-5">Search</button>
      </form>
    </section>

    <section id="craft-ideas" class="section-rule py-10">
      <p class="eyebrow">Craft ideas</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-ink">Craft ideas for using {topicLower}</h2>
      <div class="mt-5 grid gap-6 md:grid-cols-2">
        <div>
          <h3 class="font-serif text-2xl font-black text-ink">Turn pages into a mini pack</h3>
          <p class="mt-3 text-sm leading-8 text-muted">
            Use these pages for {useCase}. Print several related designs together, staple them into a
            small packet, or let kids choose their favorite page before a quiet activity.
          </p>
        </div>
        <div>
          <h3 class="font-serif text-2xl font-black text-ink">Make each page feel unique</h3>
          <p class="mt-3 text-sm leading-8 text-muted">
            Add background colors, patterns, names, story details, or a simple border after the main
            picture is finished. Heavier paper works best when using markers or paint.
          </p>
        </div>
      </div>
    </section>

    {featuredPrintable && (
      <figure class="mx-auto my-8 max-w-3xl rounded-2xl border border-line bg-white p-4 shadow-soft">
        <div class="aspect-[16/9] rounded-xl bg-mint/30 p-4">
          <div class="relative h-full overflow-hidden rounded border border-ink/20 bg-white">
            <span class="absolute left-[10%] top-[14%] h-[70%] w-[30%] rounded-2xl border-2 border-ink/24"></span>
            <span class="absolute left-[35%] top-[18%] h-[62%] w-[30%] rounded-2xl border-2 border-ink/28"></span>
            <span class="absolute right-[10%] top-[14%] h-[70%] w-[30%] rounded-2xl border-2 border-ink/24"></span>
            <span class="absolute left-[17%] top-[45%] h-2 w-[66%] rounded-full bg-pencil/50"></span>
            <span class="absolute left-[24%] top-[57%] h-2 w-[52%] rounded-full bg-sage/25"></span>
          </div>
        </div>
      </figure>
    )}

    {contentSections.length > 0 && (
      <section id="collection-guide" class="py-8">
        <p class="eyebrow">Collection guide</p>
        <h2 class="mt-3 font-serif text-3xl font-black text-ink">More ideas for {topicLower}</h2>
        <div class="mt-5 grid gap-8">
          {contentSections.map((section) => (
            <section>
              {section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
              <h3 class="mt-2 font-serif text-2xl font-black text-ink">{section.title}</h3>
              <p class="mt-3 text-sm leading-8 text-muted">{section.body}</p>
            </section>
          ))}
        </div>
      </section>
    )}

    <section id="printing-tips" class="section-rule py-10">
      <p class="eyebrow">Printing tips</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-ink">Clean print settings</h2>
      <p class="mt-4 text-sm leading-8 text-muted">
        Open the PDF, print at actual size on US Letter paper, or choose fit to page for A4. Plain
        copy paper works for crayons and pencils; heavier paper is better for markers. Print one
        test page before printing a full pack.
      </p>
    </section>

    <section id="faq" class="section-rule py-10">
      <div class="grid gap-5">
        <p class="eyebrow">FAQ</p>
        <h2 class="font-serif text-3xl font-black text-ink">Common questions</h2>
        <div class="grid gap-4 md:grid-cols-2">
          <div class="rounded-2xl border border-line bg-white p-4 shadow-soft">
            <h3 class="font-serif text-xl font-black text-ink">Can I use these in a classroom?</h3>
            <p class="mt-3 text-sm leading-6 text-muted">Yes, these printables are intended for personal, home, and classroom use unless a page says otherwise.</p>
          </div>
          <div class="rounded-2xl border border-line bg-white p-4 shadow-soft">
            <h3 class="font-serif text-xl font-black text-ink">Do I need special software?</h3>
            <p class="mt-3 text-sm leading-6 text-muted">No. Open the PDF in your browser or PDF viewer, then print it with your normal printer settings.</p>
          </div>
          <div class="rounded-2xl border border-line bg-white p-4 shadow-soft">
            <h3 class="font-serif text-xl font-black text-ink">Why are individual pages noindex?</h3>
            <p class="mt-3 text-sm leading-6 text-muted">Thin printable pages point search engines back to the stronger collection page, where visitors can compare previews and find related PDFs.</p>
          </div>
          <div class="rounded-2xl border border-line bg-white p-4 shadow-soft">
            <h3 class="font-serif text-xl font-black text-ink">Can I share a download link?</h3>
            <p class="mt-3 text-sm leading-6 text-muted">Share the collection page whenever possible so people can see the preview, license notes, related pages, and printing tips.</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  {relatedTopics.length > 0 && (
    <section id="related" class="section-rule py-10">
      <div class="mb-5">
        <p class="eyebrow">Related printables</p>
        <h2 class="mt-3 font-serif text-3xl font-black text-coral-dark">More collections to try</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {relatedTopics.map((relatedTopic) => (
          <CollectionCard
            title={relatedTopic.title}
            description={relatedTopic.description}
            href={getTopicPath(relatedTopic)}
            eyebrow="Related"
          />
        ))}
      </div>
    </section>
  )}
</article>
