---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="container-page pt-6" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2 text-sm font-bold text-muted">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-2">
          {item.href ? (
            <a href={item.href} class="rounded-full px-2 py-1 hover:bg-paper hover:text-ink">
              {item.label}
            </a>
          ) : (
            <span class="rounded-full px-2 py-1 text-ink">{item.label}</span>
          )}
          {index < items.length - 1 && <span aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
