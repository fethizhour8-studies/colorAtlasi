---
const footerLinks = [
  { label: "About", href: "/en/about/" },
  { label: "Contact", href: "/en/contact/" },
  { label: "Privacy", href: "/en/privacy-policy/" },
  { label: "Terms", href: "/en/terms/" },
  { label: "Licensing", href: "/en/licensing/" },
  { label: "DMCA", href: "/en/dmca/" },
  { label: "How to Print", href: "/en/how-to-print/" },
  { label: "AI Policy", href: "/en/ai-assisted-content-policy/" },
];
---

<footer class="mt-12 border-t border-line bg-paper">
  <div class="container-page grid gap-8 py-10 md:grid-cols-[1.2fr_1fr] md:items-start">
    <div>
      <p class="font-serif text-2xl font-black text-ink">Color Atlas</p>
      <p class="mt-3 max-w-xl text-sm leading-6 text-muted">
        Free printable coloring pages, worksheets, calendars, planners, and classroom resources,
        organized as calm catalogue pages instead of thin file listings.
      </p>
    </div>

    <nav class="flex flex-wrap gap-3 md:justify-end" aria-label="Footer navigation">
      {
        footerLinks.map((item) => (
          <a href={item.href} class="rounded-full border-2 border-line bg-ivory px-4 py-2 text-sm font-bold text-muted hover:text-ink">
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
