---
interface Props {
  title: string;
  description: string;
  href: string;
  eyebrow?: string;
  action?: string;
}

const { title, description, href, eyebrow, action = "Open collection" } = Astro.props;
---

<a href={href} class="category-tile block p-3 transition">
  <div class="category-art">
    <span class="left-[39%] top-[26%] size-10 rounded-full"></span>
    <span class="bottom-[22%] left-[32%] h-12 w-24 rounded-t-full border-b-0"></span>
    <span class="bottom-[16%] left-[28%] h-7 w-28 rounded-b-2xl"></span>
  </div>
  <div class="pt-3 text-center">
    {eyebrow && <p class="text-[0.68rem] font-black uppercase text-sage-dark">{eyebrow}</p>}
    <h3 class="mt-1 font-serif text-lg font-black leading-tight text-ink">{title}</h3>
    <p class="mx-auto mt-2 max-w-xs text-xs leading-5 text-muted">{description}</p>
    <span class="mt-3 inline-flex text-xs font-black text-sky-dark">{action}</span>
  </div>
</a>
