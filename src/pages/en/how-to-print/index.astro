---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="How to Print Coloring Pages | Coloring Atlas" description="Simple printing help for Coloring Atlas PDF printables." canonicalPath="/en/how-to-print/">
  <section class="section trust-page">
    <p class="eyebrow">Printing help</p>
    <h1>How to print Coloring Atlas PDFs</h1>
    <p class="lead">Download the PDF, open it in your browser or PDF viewer, and print at actual size for US Letter. For A4 paper, choose fit to page.</p>
    <div class="panel guide">
      <h2>Basic settings</h2>
      <p>Use portrait or landscape based on the file preview. Keep margins normal unless your printer requires a specific setting.</p>
      <p>For detailed adult pages, heavier paper can work better with markers. For kids pages and classroom packets, plain copy paper is usually enough.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .trust-page {
    max-width: 920px;
  }

  .guide {
    display: grid;
    gap: 0.8rem;
    margin-top: 1.5rem;
    padding: 1.1rem;
  }
</style>
