---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CollectionCard from "@/components/CollectionCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  breadcrumbJsonLd,
  buildContentTypeSeo,
  collectionJsonLd,
  contentTypes,
  getContentTypePath,
  getHubPath,
  getHubsForContentType,
  getPrintablesForTopic,
  getRootTopicsForContentType,
  getTopicPath,
  getTopicsForContentType,
  getTopicsForHub,
} from "@/lib/catalog";
import type { ContentType } from "@/lib/catalog";

export function getStaticPaths() {
  return contentTypes.map((contentType) => ({
    params: { contentType: contentType.slug },
    props: { contentType },
  }));
}

interface Props {
  contentType: ContentType;
}

const { contentType } = Astro.props;
const seo = buildContentTypeSeo(contentType);
const hubs = getHubsForContentType(contentType.id);
const rootTopics = getRootTopicsForContentType(contentType.id);
const allTopics = getTopicsForContentType(contentType.id);
const printableCount = allTopics.reduce(
  (total, topic) => total + getPrintablesForTopic(topic.id).length,
  0,
);
const breadcrumbItems = [{ label: "Home", href: "/en/" }, { label: contentType.title }];
const pageIntro =
  contentType.id === "coloring-pages"
    ? "Start with broad, safe collections like kids coloring pages, animals, mandalas, and calm adult printables. Each collection is built around original ideas rather than protected characters or brand names."
    : contentType.id === "calendars"
      ? "Use these calendar pages for monthly planning, classroom schedules, desk organization, and family routines. Keep the year and month pages clean, printable, and easy to update."
      : contentType.id === "worksheets"
        ? "Worksheets should stay useful for early learners, parents, and teachers: simple instructions, readable practice areas, and classroom-friendly topics."
        : "Planner pages should feel calm, useful, and printable, with clear sections for routines, notes, priorities, and simple organization.";
---

<BaseLayout
  title={`${seo.title} | Color Atlas`}
  description={seo.description}
  canonicalPath={seo.canonicalPath}
  robots={seo.robots}
  jsonLd={[collectionJsonLd(contentType, getContentTypePath(contentType), printableCount), breadcrumbJsonLd(breadcrumbItems)]}
>
  <Breadcrumbs items={breadcrumbItems} />

  <section class="content-page py-10 text-center">
    <div>
      <p class="eyebrow">{printableCount} printable PDF{printableCount === 1 ? "" : "s"}</p>
      <h1 class="mt-4 font-serif text-[clamp(2.4rem,6vw,4.2rem)] font-black leading-none text-ink">
        {contentType.title}
      </h1>
      <p class="mt-5 text-base leading-7 text-muted">{contentType.description}</p>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-muted">{pageIntro}</p>
    </div>
  </section>

  <section class="container-page py-8">
    <div class="grid gap-4 md:grid-cols-3">
      <div class="sidebar-box bg-ivory p-4">
        <p class="eyebrow">Browse</p>
        <h2 class="mt-2 font-serif text-2xl font-black text-ink">Choose a shelf</h2>
        <p class="mt-3 text-sm leading-6 text-muted">Start with a hub or collection, then use the printable grid to choose the exact PDF you want.</p>
      </div>
      <div class="sidebar-box bg-mint/50 p-4">
        <p class="eyebrow">Print</p>
        <h2 class="mt-2 font-serif text-2xl font-black text-ink">Use simple PDFs</h2>
        <p class="mt-3 text-sm leading-6 text-muted">Pages are organized around direct PDF downloads, visible previews, and short printing tips.</p>
      </div>
      <div class="sidebar-box bg-sun/20 p-4">
        <p class="eyebrow">Trust</p>
        <h2 class="mt-2 font-serif text-2xl font-black text-ink">Keep topics safe</h2>
        <p class="mt-3 text-sm leading-6 text-muted">Expansion should prioritize evergreen, non-copyright topics before chasing high-risk character searches.</p>
      </div>
    </div>
  </section>

  <section class="container-page py-8">
    <div>
      <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div>
          <p class="eyebrow">Browse shelves</p>
          <h2 class="font-serif text-3xl font-black text-coral-dark">Subcategories</h2>
        </div>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          hubs.map((hub) => (
            <CollectionCard
              title={hub.title}
              description={hub.description}
              href={getHubPath(hub)}
              eyebrow={`${getTopicsForHub(hub.id).length} collection${getTopicsForHub(hub.id).length === 1 ? "" : "s"}`}
              action="Browse hub"
            />
          ))
        }
        {
          rootTopics.map((topic) => (
            <CollectionCard
              title={topic.title}
              description={topic.description}
              href={getTopicPath(topic)}
              eyebrow={`${getPrintablesForTopic(topic.id).length} PDF${getPrintablesForTopic(topic.id).length === 1 ? "" : "s"}`}
              action="Open collection"
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
