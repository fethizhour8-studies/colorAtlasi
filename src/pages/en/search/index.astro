---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Search Printable Pages | Color Atlas"
  description="Search Color Atlas for printable coloring pages, worksheets, calendars, planners, collections, and PDF pages."
  canonicalPath="/en/search/"
>
  <section class="content-page py-10">
    <p class="eyebrow">Site search</p>
    <h1 class="mt-4 font-serif text-[clamp(2.4rem,6vw,4.2rem)] font-black leading-none text-ink">
      Search printable pages
    </h1>
    <p class="mt-5 max-w-2xl text-base leading-7 text-muted">
      Search the full catalogue for coloring pages, worksheets, calendars, planners, collections, and individual printable PDFs.
    </p>

    <form class="mt-8 grid gap-3 md:grid-cols-[minmax(0,1fr)_auto]" role="search" action="/en/search/">
      <label class="sr-only" for="site-search-input">Search Color Atlas</label>
      <input
        id="site-search-input"
        name="q"
        type="search"
        placeholder="Search animals, mandalas, calendars, worksheets..."
        class="min-h-12 rounded-full border border-line bg-paper px-4 text-sm font-bold text-ink outline-none focus:border-sky"
      />
      <button class="button-primary min-h-12 px-6" type="submit">Search</button>
    </form>

    <div id="search-summary" class="mt-6 text-sm font-bold text-muted"></div>
    <div id="search-results" class="mt-6 grid gap-4"></div>
  </section>

  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const query = (params.get("q") || "").trim();
    const input = document.getElementById("site-search-input");
    const summary = document.getElementById("search-summary");
    const results = document.getElementById("search-results");

    if (input) input.value = query;

    const normalize = (value) => String(value || "").toLowerCase();
    const renderResult = (item) => `
      <article class="rounded-2xl border border-line bg-white p-5 shadow-soft">
        <p class="eyebrow">${item.type}${item.count ? ` · ${item.count} item${item.count === 1 ? "" : "s"}` : ""}</p>
        <h2 class="mt-2 font-serif text-2xl font-black text-ink"><a href="${item.url}">${item.title}</a></h2>
        <p class="mt-2 text-sm leading-6 text-muted">${item.description}</p>
        <div class="mt-3 flex flex-wrap gap-2">${(item.tags || []).slice(0, 6).map((tag) => `<span class="rounded-full border border-line bg-paper px-2 py-1 text-xs font-bold text-muted">${tag}</span>`).join("")}</div>
      </article>
    `;

    async function runSearch() {
      const response = await fetch("/search-index.json");
      const items = await response.json();

      if (!query) {
        summary.textContent = "Type a keyword to search the catalogue.";
        results.innerHTML = items.slice(0, 8).map(renderResult).join("");
        return;
      }

      const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
      const matches = items
        .map((item) => {
          const haystack = normalize([item.title, item.description, ...(item.tags || [])].join(" "));
          const score = terms.reduce((total, term) => total + (haystack.includes(term) ? 1 : 0), 0);
          return { item, score };
        })
        .filter((entry) => entry.score > 0)
        .sort((a, b) => b.score - a.score || a.item.title.localeCompare(b.item.title))
        .map((entry) => entry.item);

      summary.textContent = `${matches.length} result${matches.length === 1 ? "" : "s"} for “${query}”.`;
      results.innerHTML = matches.length ? matches.map(renderResult).join("") : "<p class='text-sm font-bold text-muted'>No matching printables yet. Try a broader keyword.</p>";
    }

    runSearch();
  </script>
</BaseLayout>
